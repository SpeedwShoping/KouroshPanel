[Unit]
Description=kourosh Service
After=network.target
Wants=network.target

[Service]
EnvironmentFile=-/etc/conf.d/kourosh
Environment="XRAY_VMESS_AEAD_FORCED=false"
Type=simple
WorkingDirectory=/usr/local/kourosh/
ExecStart=/usr/local/kourosh/kourosh
ExecReload=/bin/kill -USR1 $MAINPID
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
